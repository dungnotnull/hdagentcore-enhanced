# =============================================================================
# agentcore-enhanced Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys and configuration.
# At minimum, configure one LLM provider (Claude, OpenAI, Azure, GCP, Ollama, or vLLM).
#
# Security Notes:
# - Never commit .env to version control
# - Use strong, randomly generated API keys
# - Rotate keys regularly
# - Use separate keys for development/staging/production
# - Limit key scopes to minimum required permissions
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider Configuration
# -----------------------------------------------------------------------------
# Configure at least one provider. The system will fallback through:
# Claude → OpenAI → Azure → GCP → Ollama → vLLM
# -----------------------------------------------------------------------------

# Claude (Anthropic) - Recommended for best reasoning quality
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Azure AI Foundry (Azure OpenAI)
# Get your endpoint and key from Azure Portal
AZURE_OPENAI_API_KEY=your-azure-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01

# GCP Vertex AI
# Project must have Vertex AI API enabled
# Requires Application Default Credentials (ADC) setup
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Ollama (Local Inference)
# Requires Ollama running locally or accessible at URL
# Download from: https://ollama.ai/
OLLAMA_BASE_URL=http://localhost:11434

# vLLM (Local Inference)
# Requires vLLM server running
# GitHub: https://github.com/vllm-project/vllm
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=

# -----------------------------------------------------------------------------
# Model Selection
# -----------------------------------------------------------------------------
# Override default models for each provider
# -----------------------------------------------------------------------------

# Claude models: claude-opus-4-8, claude-sonnet-4-6
CLAUDE_DEFAULT_MODEL=claude-opus-4-8

# OpenAI models: gpt-4o, gpt-4o-mini, gpt-4-turbo
OPENAI_DEFAULT_MODEL=gpt-4o

# Azure models (same as OpenAI)
AZURE_DEFAULT_MODEL=gpt-4o

# GCP models: gemini-1.5-pro, gemini-1.5-flash
GCP_DEFAULT_MODEL=gemini-1.5-pro

# Ollama models: llama3, mistral, codellama, etc.
OLLAMA_DEFAULT_MODEL=llama3

# vLLM models (depends on what you're serving)
VLLM_DEFAULT_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# -----------------------------------------------------------------------------
# Privacy & Offline Mode
# -----------------------------------------------------------------------------
# When enabled, only uses local providers (Ollama, vLLM)
# No data sent to external APIs
# -----------------------------------------------------------------------------
PRIVACY_MODE=false

# -----------------------------------------------------------------------------
# Knowledge Crawler Configuration
# -----------------------------------------------------------------------------
# Daily research paper crawler settings
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_your-github-token-here
ENABLE_DAILY_CRAWL=true
CRAWL_SCHEDULE=06:00
MAX_PAPERS_PER_DAY=10

# -----------------------------------------------------------------------------
# HuggingFace Configuration
# -----------------------------------------------------------------------------
# Models: BAAI/bge-large-en-v1.5, sentence-transformers/all-MiniLM-L6-v2
#          Salesforce/codet5p-770m, BAAI/bge-reranker-large
# -----------------------------------------------------------------------------
HF_HOME=/app/models
HF_HUB_CACHE=/app/models/hub
HF_DATASETS_CACHE=/app/models/datasets

# Force CPU even if CUDA available (for testing)
HF_FORCE_CPU=false

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=7865
WORKERS=1
RELOAD=false

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# SQLite database for storing runs, benchmarks, and costs
# -----------------------------------------------------------------------------
DATABASE_PATH=/app/data/agentcore.db

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Valid levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Benchmark Configuration
# -----------------------------------------------------------------------------
# Evaluation benchmark settings
# -----------------------------------------------------------------------------
BENCHMARK_JUDGE_MODEL=claude-sonnet-4-6
COMPOSITE_SCORE_THRESHOLD=0.40
LATENCY_MAX_MS=30000

# -----------------------------------------------------------------------------
# MCP Tool Configuration
# -----------------------------------------------------------------------------
# Model Context Protocol tool settings
# -----------------------------------------------------------------------------
MCP_SERVER_PORT=8765
CODE_EXEC_TIMEOUT=10
WORKSPACE_PATH=/app/workspace

# -----------------------------------------------------------------------------
# Prometheus Metrics
# -----------------------------------------------------------------------------
# Enable/disable Prometheus metrics endpoint
# -----------------------------------------------------------------------------
ENABLE_METRICS=true
METRICS_PATH=/metrics

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# CORS settings for API server
# -----------------------------------------------------------------------------
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# Request size limits
MAX_REQUEST_SIZE=10MB
MAX_TOOL_RESULT_SIZE=1MB

# -----------------------------------------------------------------------------
# Development Settings
# -----------------------------------------------------------------------------
# Enable development features (hot reload, debug endpoints, etc.)
# -----------------------------------------------------------------------------
DEBUG=false
DEV_MODE=false

# -----------------------------------------------------------------------------
# Optional: Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable experimental features
# -----------------------------------------------------------------------------
ENABLE_PATTERN_RERANKING=true
ENABLE_KNOWLEDGE_DEDUP=true
ENABLE_COST_TRACKING=true
ENABLE_ERROR_RECOVERY_TRACKING=true
