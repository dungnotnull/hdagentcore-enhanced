# ── Primary LLM (required for full functionality) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Fallback LLM providers (optional) ──────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Azure OpenAI (optional) ─────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── GCP Vertex AI (optional) ────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Ollama (local, optional — offline/privacy mode) ─────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── vLLM (self-hosted, optional) ────────────────────────────────────────────
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=token-abc123

# ── Privacy mode: forces all calls to Ollama ────────────────────────────────
PRIVACY_MODE=false

# ── GitHub token (optional — higher rate limits for release crawling) ────────
GITHUB_TOKEN=ghp_...

# ── Web search (optional — Brave Search API alternative) ────────────────────
BRAVE_SEARCH_API_KEY=

# ── Server config ────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=7865

# ── Database path ────────────────────────────────────────────────────────────
DB_PATH=./data/agentcore.db
